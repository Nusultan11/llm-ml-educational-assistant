# Ignore Python build and cache
__pycache__/
*.pyc
*.pyo
*.pyd
*.egg-info/
dist/
build/

# Virtual environments
.env
.venv/
env/
ml/

# Jupyter
.ipynb_checkpoints/

# Runtime outputs
logs/
artifacts/
.cache/

# Model binaries and checkpoints
*.faiss
*.bin
*.pt
*.ckpt

# Data policy:
# keep data private by default, but allow tracked examples
/data/*
!/data/examples/
!/data/examples/**
!/data/README.md

# Optional external datasets
/datasets/
